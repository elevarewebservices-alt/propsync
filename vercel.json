{
  "crons": [
    {
      "path": "/api/cron/wasi-sync",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/follow-up-reminders",
      "schedule": "0 8 * * 1-5"
    },
    {
      "path": "/api/cron/automations",
      "schedule": "0 9 * * *"
    }
  ],
  "headers": [
    {
      "source": "/.well-known/apple-app-site-association",
      "headers": [{ "key": "Content-Type", "value": "application/json" }]
    }
  ]
}
