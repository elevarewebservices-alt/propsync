# Copia este archivo como .env y completa los valores reales

# API de WASender
WASENDER_API_KEY=TU_API_KEY_AQUI
WASENDER_BASE_URL=https://www.wasenderapi.com/api

# Seguridad del webhook (copia el secreto que te da WASender en su panel)
WEBHOOK_SECRET=

# Delay entre mensajes (segundos) — protege tu número
DELAY_MIN=60
DELAY_MAX=120

# API de Wasi CRM
WASI_ID_COMPANY=2946576
WASI_TOKEN=TU_WASI_TOKEN_AQUI
WASI_BASE_URL=https://api.wasi.co/v1
