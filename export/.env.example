# ── WhatsApp Cloud API (Meta) ──────────────────────────────────────────────
# developers.facebook.com → tu app → WhatsApp → API Setup
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
# Token que TÚ inventas; debe coincidir con el que pones en la config del webhook en Meta
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
# App secret de Meta — para verificar la firma de los webhooks (X-Hub-Signature-256)
WHATSAPP_APP_SECRET=

# ── Anthropic (Claude) ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
# Modelo: haiku = barato (default), sonnet = mejor conversación para ventas
ASSISTANT_MODEL=claude-haiku-4-5-20251001

# ── Supabase ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Opcional: conectar al inventario de PropSync ──────────────────────────
# Si se llena, el bot busca propiedades en PropSync en vez de la tabla local
PROPSYNC_API_URL=
PROPSYNC_API_KEY=
